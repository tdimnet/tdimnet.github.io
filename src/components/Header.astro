---
import Heading from "./Heading.astro";
import Paragraph from "./Paragraph.astro";
import GithubIcon from "../icons/Github.astro";
import MediumIcon from "../icons/Medium.astro";

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";

const navLinks = [
  { href: "/teaching", label: "Teaching" },
  { href: "/projects", label: "Projects" },
  { href: "/publications", label: "Publications" },
  { href: "/experimentations", label: "Experimentations" },
];

const activeCss = (href: string) =>
  pathname === href ? "underline decoration-secondary underline-offset-4" : "";

const isActive = (href: string) => (pathname === href ? "page" : undefined);
---

<header class="row-span-1">
  <nav aria-label="Main navigation">
    <ul class="flex flex-row items-end mb-3">
      <li class="mr-2 lg:mr-5">
        <a href="/" aria-label="Home">
          <Heading css="text-white" content="tom" as="h3" />
        </a>
      </li>
      {
        navLinks.map((link) => (
          <li class="hidden md:block mr-2 lg:mr-5">
            <a href={link.href} aria-current={isActive(link.href)}>
              <Paragraph css={activeCss(link.href)}>{link.label}</Paragraph>
            </a>
          </li>
        ))
      }
      <li class="ml-auto mr-2 lg:mr-5">
        <a
          class="opacity-80 hover:opacity-100 ease-in duration-200 hover:scale-125"
          href="https://github.com/tdimnet"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub profile (opens in a new tab)"
        >
          <GithubIcon />
        </a>
      </li>
      <li class="">
        <a
          class="opacity-80 hover:opacity-100 ease-in duration-200 hover:scale-125"
          href="https://tdimnet.medium.com/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Medium profile (opens in a new tab)"
        >
          <MediumIcon />
        </a>
      </li>
    </ul>
    <ul class="md:hidden w-4/5 overflow-x-scroll">
      {
        navLinks.map((link) => (
          <li class="mr-2">
            <a href={link.href} aria-current={isActive(link.href)}>
              <Paragraph css={activeCss(link.href)}>{link.label}</Paragraph>
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
