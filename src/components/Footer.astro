---
import Heading from "./Heading.astro";
import GithubIcon from "../icons/Github.astro";
import MediumIcon from "../icons/Medium.astro";
---

<footer
  class="flex flex-col justify-center items-center border-t-2 border-white pt-5 md:flex-row"
>
  <a href="/">
    <Heading css="text-white mb-5" content="tom" as="h3" />
  </a>
  <ul class="grid grid-cols-2 md:ml-auto">
    <li>
      <a
        class="ml-auto mr-5 opacity-80 hover:opacity-100 ease-in duration-200 hover:scale-125"
        href="https://github.com/tdimnet"
        target="_blank"
        rel="noopener noreferrer"
      >
        <GithubIcon />
      </a>
    </li>
    <li>
      <a
        class="opacity-80 hover:opacity-100 ease-in duration-200 hover:scale-125"
        href="https://tdimnet.medium.com/"
        target="_blank"
        rel="noopener noreferrer"
      >
        <MediumIcon />
      </a>
    </li>
  </ul>
</footer>
