---
interface Props {
    alt: string
    src: ImageMetadata
}

import { Image } from "astro:assets"

const {
    alt, src
} = Astro.props
---

<div class="banner">
  <Image
    src={src}
    class="hero-image"
    alt={alt}
  />
</div>

<style>
  .banner {
    height: 320px;
  }

  .banner img {
    height: 100%;
    object-fit: cover;
  }
</style>
